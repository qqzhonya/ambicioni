.modal.modal-discussion(data-modal="discussion-modal")
	.modal-bg
	.modal-body
		.modal-close
		.modal-heading Обсудить с менеджером
		.modal-discussion-info-wrap
			.modal-discussion-info-elem
				.modal-discussion-info-img-box
					img(src="style/img/product-img-1.jpg", alt="").modal-discussion-info-img
			.modal-discussion-info-elem
				.modal-discussion-info-name Обувной шкаф Contorno
		form(action="").modal-form
			input(type="text" placeholder="Имя").modal-input
			input(type="text" placeholder="Телефон").modal-input
			.modal-form-delimer Или
			input(type="text" placeholder="Email").modal-input
			button.default-btn.modal-form-btn Отправить

