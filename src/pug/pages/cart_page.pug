							textarea(name="comment" placeholder="Ваш комментарий" maxlength="250").cart-comment-textarea
							.cart-comment-form-bottom
								.cart-comment-symbols
									span.cart-comment-symbols-value 0 
									span.cart-comment-symbols-max / 250
								.cart-comment-save Сохранить

			.cart-product
