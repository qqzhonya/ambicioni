include ../var/top_line.pug

.wrapper-box
	.wrapper
		.wrapper-header Сотрудничество

		.about
			.about-heading Дизайнерам
			p.custom-text
				| Ретро-дизайн с современным кроем. Две раздвижные двери, три отделения с полками. 
				| Яркие контрастные внутренние вставки окрашенные эмалью на фоне натуральной древесины 
				| придают ему особый вид.
			.custom-list-wrap
				.custom-list-title Список:
				ol.custom-list
					li Первый пункт
					li Второй пункт
					li Третий пункт
					li Четвертый пункт
					li Пятый пункт
					li Особая привелегия
			p.custom-text
				| Ретро-дизайн с современным кроем. Две раздвижные двери, три отделения с полками. 
				| Яркие контрастные внутренние вставки окрашенные эмалью на фоне натуральной древесины 
				| придают ему особый вид.
	
		.cooperation-wrap
			.cooperation-img-wrap
				img(src="style/img/cooperation-img.jpg", alt="").cooperation-img
			.cooperation-info
				.about-heading Партнерам
				p.custom-text
					| Ретро-дизайн с современным кроем. Две раздвижные двери, три отделения с полками. 
					| Яркие контрастные внутренние вставки окрашенные эмалью на фоне натуральной 
					| древесины придают ему особый вид.
				.custom-list-wrap
					.custom-list-title Список:
					ul.custom-list.custom-list-check
						li Первый пункт
						li Второй пункт
						li Третий пункт
						li Четвертый пункт
						li Пятый пункт
						li Особая привелегия
				p.custom-text
					| Ретро-дизайн с современным кроем. Две раздвижные двери, три отделения с полками. 
					| Яркие контрастные внутренние вставки окрашенные эмалью на фоне натуральной 
					| древесины придают ему особый вид.
			
		form(action="").cooperation-form
			.cooperation-form-title Форма связи
			.cooperation-form-radio-wrap
				.cooperation-form-radio-elem
					input(type="radio" name="cooperationRadio" checked).cooperation-form-radio.cooperation-form-radio-design#cooperation-design
					label(for="cooperation-design").cooperation-form-radio-label Дизайнер
				.cooperation-form-radio-elem
					input(type="radio" name="cooperationRadio").cooperation-form-radio.cooperation-form-radio-dealer#cooperation-dealer
					label(for="cooperation-dealer").cooperation-form-radio-label Диллер
			.cooperation-form-wrap.cooperation-form-design.active
				.cooperation-form-elem
					input(type="text" placeholder="ФИО").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Телефон").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Дизайн студия").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Email").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Ссылка на сайт / инстаграм").cooperation-form-input
				.cooperation-form-elem
					button.default-btn.cooperation-form-btn Отправить
			.cooperation-form-wrap.cooperation-form-dealer
				.cooperation-form-elem
					input(type="text" placeholder="ФИО").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Телефон").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Наименование компании").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Email").cooperation-form-input
				.cooperation-form-elem
					input(type="text" placeholder="Ссылка на сайт / инстаграм").cooperation-form-input
				.cooperation-form-elem
					button.default-btn.cooperation-form-btn Отправить
			
	a(href="").inst.inst-single
		.inst-wrap
			.inst-title
				.inst-logo
					img(src="style/img/icon/inst-icon.svg", alt="")
				.inst-text Ambicioni

	include ../var/footer.pug