include ../var/top_line.pug

.wrapper-box
	.wrapper
		.wrapper-header Корзина
	
		.cart
			.cart-product
				.cart-img-box
					img(src="style/img/product-img-1.jpg", alt="").cart-img
				.cart-product-wrap
					.cart-top
						.cart-info
							.cart-name Обувной шкаф Contorno
							.cart-size
								span.cart-size-text Размер: 
								span.cart-size-value 80х35х87.5 см
						.cart-number
							input(type="text" placeholder="0" value="1").cart-number-input
							.cart-number-control
								span.cart-number-plus
								span.cart-number-minus
						.cart-price 57 800 ₽
						.cart-delete
					.cart-bottom
						.cart-comment-btn

	a(href="").inst.inst-single
		.inst-wrap
			.inst-title
				.inst-logo
					img(src="style/img/icon/inst-icon.svg", alt="")
				.inst-text Ambicioni

	include ../var/footer.pug